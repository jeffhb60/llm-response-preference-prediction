    "\n",
    "    blended_valid_probs = clip_and_normalize(blended_valid_probs)\n",
    "    score = log_loss(valid_labels, blended_valid_probs, labels=[0, 1, 2])\n",
    "\n",
    "    blend_results.append({\n",
